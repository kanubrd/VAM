# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Node Environment
NODE_ENV=production

# Next.js Build Optimization
NEXT_TELEMETRY_DISABLED=1
NODE_OPTIONS=--max-old-space-size=4096

# SMTP Configuration (Required for email functionality)
# Use Gmail, SendGrid, AWS SES, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Company Email (Where form submissions are sent)
COMPANY_EMAIL=info@valtrixmaterials.com

# Public URL (for email assets like logos)
# Use your production URL in production, localhost for local testing
NEXT_PUBLIC_SITE_URL=https://valtrixmaterials.com

# Admin Dashboard Authentication
# Change this to a strong password in production
ADMIN_PASSWORD=your-secure-admin-password

# Optional: External API Backend
# NEXT_PUBLIC_API_URL=https://your-api.com

# Vercel (for GitHub Actions - optional)
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=
